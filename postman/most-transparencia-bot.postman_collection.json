  "item": [
    {
      "name": "Healthcheck",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"Health status is ok\", function () {",
              "  pm.expect(json.status).to.eql(\"ok\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Consulta - Sucesso por Nome",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"Retorna status conhecido\", function () {",
              "  pm.expect([\"sucesso\", \"sem_resultados\"]).to.include(json.status);",
              "});",
              "",
              "pm.test(\"Possui estrutura principal\", function () {",
              "  pm.expect(json).to.have.property(\"nome_busca\");",
              "  pm.expect(json).to.have.property(\"url_busca\");",
              "  pm.expect(json).to.have.property(\"status\");",
              "});",
              "",
              "if (json.status === \"sucesso\") {",
              "  pm.test(\"Sucesso contém dados detalhados\", function () {",
              "    pm.expect(json.resultado_clicado).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(json.url_detalhe).to.be.a(\"string\").and.include(\"portaldatransparencia.gov.br\");",
              "    pm.expect(json.tabela_detalhada).to.be.an(\"object\");",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identificador\": \"Maria\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/consulta-script",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "consulta-script"
          ]
        }
      }
    },
